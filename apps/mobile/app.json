{
  "expo": {
    "name": "Internably",
    "slug": "internably-mobile",
    "entryPoint": "./node_modules/expo-router/entry",
    "scheme": "internably",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#F7F2E8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F2E8"
      }
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "extra": {
      "apiUrl": "http://localhost:4000/api"
    }
  }
}
