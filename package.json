{
  "name": "internably-mvp",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev -w apps/api",
    "dev:mobile": "npm run start -w apps/mobile",
    "build": "npm run build -w apps/api && npm run build -w packages/types && npm run build -w packages/ui",
    "db:generate": "npm run prisma:generate -w apps/api",
    "db:migrate": "npm run prisma:migrate -w apps/api",
    "db:seed": "npm run prisma:seed -w apps/api"
  }
}
